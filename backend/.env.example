# ===========================================
# Producteev Backend - Environment Example
# ===========================================
# Copy this file to .env and fill in your values

# ---------- Node Environment ----------
NODE_ENV=development
PORT=4000

# ---------- DATABASE ----------
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/producteev?schema=public

# For Railway production:
DATABASE_URL=postgresql://postgres:JrukktONTgAcLdARbhxExscPxia3cLrS@postgres.railway.internal:5432/railway?schema=public&sslmode=require

# ---------- REDIS ----------
# Optional: Set Redis URL (leave empty to disable Redis)
# REDIS_URL=redis://localhost:6379

# ---------- JWT SECRETS ----------
# Generate with: openssl rand -base64 64
# IMPORTANT: Change these in production!
JWT_SECRET=your-super-secret-key-at-least-32-characters-long-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173
ALLOW_LOCALHOST_CORS=true

# ---------- FRONTEND ----------
FRONTEND_URL=http://localhost:5173

# ---------- EMAIL CONFIGURATION (Optional) ----------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SERVICE=gmail
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM="Producteev <your-email@gmail.com>"

# ---------- SLACK INTEGRATION (Optional) ----------
# SLACK_APP_TOKEN=xapp-xxx
# SLACK_CLIENT_ID=xxx
# SLACK_CLIENT_SECRET=xxx
# SLACK_BOT_TOKEN=xoxb-xxx
# PUBLIC_BASE_URL=http://localhost:4000
# SLACK_REDIRECT_URI=http://localhost:4000/api/v1/slack/oauth/callback
