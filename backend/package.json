{
  "name": "@clickup-pms/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-port.mjs 4000",
    "prestart": "npm run db:migrate:prod",
    "dev": "tsx --env-file=.env --watch src/index.ts",
    "build": "prisma generate && (tsc || echo 'Build continued with warnings')",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "node scripts/run-migrations.mjs",
    "db:baseline": "node scripts/baseline-db.mjs",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "@prisma/engines": "^6.19.3",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.1",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "resend": "^6.10.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.11",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "5.14.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
