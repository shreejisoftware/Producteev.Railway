# Production environment example for backend (DO NOT store secrets in repo)
# Copy these names into Railway variables and set the secret values there.

# Database - use Railway internal URL for backend services
DATABASE_URL=postgresql://postgres:JrukktONTgAcLdARbhxExscPxiaJcLrS@postgres.railway.internal:5432/railway
# Optional public URL for local tools (psql, DBeaver)
DATABASE_PUBLIC_URL=postgresql://postgres:JrukktONTgAcLdARbhxExscPxiaJcLrS@turntable.proxy.rlwy.net:31830/railway

# Redis (optional) - leave blank if you don't use Redis in production
REDIS_URL=

# JWT secrets - generate securely and paste into Railway
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=365d

# App settings
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://producteevpro.up.railway.app
FRONTEND_URL=https://producteevpro.up.railway.app
ALLOW_LOCALHOST_CORS=false

# SMTP / Email (use app password and set as secret)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=shreejisoftware1@gmail.com
SMTP_PASS=
EMAIL_FROM="Shreeji Software <shreejisoftware1@gmail.com>"

# Notes:
# - Never commit real passwords or JWT secrets into source control.
# - Use Railway's Variables UI to set the real values.
# - To generate secure secrets: `openssl rand -base64 64` (copy output into JWT_SECRET and JWT_REFRESH_SECRET)
